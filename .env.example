# ===== AI Shorts Factory configuration =====
# Copy to .env and fill in. All values have sensible defaults except API keys.

# --- Text generation (Gemini) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Image generation ---
# Provider: "gemini" (Imagen 3, high quality, uses GEMINI_API_KEY) |
#          "pollinations" (free fallback, lower quality)
IMAGE_PROVIDER=gemini
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001

# --- Voiceover / TTS ---
# Provider: "edge" (free, no key) | "elevenlabs" (needs key)
TTS_PROVIDER=edge
# Set to "random" to rotate between 5 deep male voices per video (recommended
# for variety on the feed). Or pick one: en-US-GuyNeural, en-US-DavisNeural,
# en-GB-RyanNeural, en-AU-WilliamNeural, en-US-AndrewNeural
EDGE_TTS_VOICE=random
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# --- Content theme ---
# Cohesive faceless channel identity; topics auto-rotate across curiosity
# formats (what-if, terrifying fact, unsolved mystery, future, discovery...) and
# subjects (space, deep ocean, human body, physics, future...) within the theme.
# Options: mixed-curiosity (default, broadest) | what-if-disaster |
#          space-mysteries | deep-ocean
CONTENT_THEME=cosmic-dread
# Hard-lock generation to the winning space/cosmic-dread niche (anti topic-drift)
NICHE_LOCK=true
CONTENT_LANGUAGE=en
SCENES_PER_VIDEO=6

# --- Video / render ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# Ambient music bed. Leave unset to use the bundled assets/music/ambient_drone.mp3,
# set to your own mp3 path to override, or set empty (BACKGROUND_MUSIC=) to disable.
# BACKGROUND_MUSIC=assets/music/ambient_drone.mp3
MUSIC_VOLUME=0.16

# --- Quality / production polish ---
TRANSITION_DURATION=0.35   # crossfade seconds between scenes (0 = hard cuts)
IMAGE_ENHANCE=true         # Pollinations enhance + sharpening/grade on images
FILM_GRAIN=true            # subtle cinematic film grain
ENABLE_SFX=true            # whoosh SFX on each scene transition
SFX_VOLUME=0.35
# Opening impact hit — a sub-0.2s bass thud at frame 0 to grab attention instantly.
# SFX_IMPACT_FILE=assets/sfx/impact.mp3
SFX_IMPACT_VOLUME=0.55

# --- Stock video (Pexels) ---
# Free API key from https://www.pexels.com/api/ — enables real stock footage
# clips instead of static AI images (massive quality upgrade).
PEXELS_API_KEY=
USE_STOCK_VIDEO=true

# --- YouTube upload ---
# Path to OAuth client secret JSON downloaded from Google Cloud Console.
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
# Stored refresh token (used in CI instead of token.json). Optional.
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public   # public | unlisted | private
YOUTUBE_CATEGORY_ID=27          # 27 = Education
YOUTUBE_MADE_FOR_KIDS=false
