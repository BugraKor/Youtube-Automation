# ===== AI Shorts Factory configuration =====
# Copy to .env and fill in. All values have sensible defaults except API keys.

# --- Text generation (Gemini) ---
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash

# --- Image generation ---
# Provider: "pollinations" (free, no key) | "gemini" (Imagen, needs GEMINI_API_KEY)
IMAGE_PROVIDER=pollinations
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# --- Voiceover / TTS ---
# Provider: "edge" (free, no key) | "elevenlabs" (needs key)
TTS_PROVIDER=edge
EDGE_TTS_VOICE=en-US-GuyNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# --- Content theme ---
CONTENT_THEME=what-if-disaster
CONTENT_LANGUAGE=en
SCENES_PER_VIDEO=6

# --- Video / render ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# Ambient music bed. Leave unset to use the bundled assets/music/ambient_drone.mp3,
# set to your own mp3 path to override, or set empty (BACKGROUND_MUSIC=) to disable.
# BACKGROUND_MUSIC=assets/music/ambient_drone.mp3
MUSIC_VOLUME=0.16

# --- Quality / production polish ---
TRANSITION_DURATION=0.35   # crossfade seconds between scenes (0 = hard cuts)
IMAGE_ENHANCE=true         # Pollinations enhance + sharpening/grade on images
FILM_GRAIN=true            # subtle cinematic film grain
ENABLE_SFX=true            # whoosh SFX on each scene transition
SFX_VOLUME=0.35

# --- YouTube upload ---
# Path to OAuth client secret JSON downloaded from Google Cloud Console.
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
# Stored refresh token (used in CI instead of token.json). Optional.
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=public   # public | unlisted | private
YOUTUBE_CATEGORY_ID=27          # 27 = Education
YOUTUBE_MADE_FOR_KIDS=false
